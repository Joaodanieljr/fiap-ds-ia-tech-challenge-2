# ==========================================
# AUTENTICAÇÃO AZURE (OPCIONAL)
# ==========================================
AZURE_CLIENT_ID=seu_client_id_aqui
AZURE_CLIENT_SECRET=seu_client_secret_aqui
AZURE_TENANT_ID=seu_tenant_id_aqui
AZURE_SUBSCRIPTION_ID=sua_subscription_id_aqui

# ==========================================
# STORAGE ACCOUNT E CONEXÃO
# ==========================================
STORAGE_ACCOUNT_NAME=stterraformstate
AZURE_STORAGE_ACCOUNT_NAME=nome_do_seu_storage_account
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net"

# ==========================================
# PIPELINE BATCH / STREAMING
# ==========================================
TABLE_NAME=alfabetizacao
EH_CONNECTION_STRING=Endpoint=sb://seu-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=sua-chave
EVENTHUB_NAME=nome-do-event-hub
AMBIENTE=desenvolvimento