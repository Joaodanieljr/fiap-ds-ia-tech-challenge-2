# ==========================================
# AUTENTICAÇÃO AZURE (para Terraform e scripts)
# ==========================================
AZURE_CLIENT_ID=seu_client_id_aqui
AZURE_CLIENT_SECRET=seu_client_secret_aqui
AZURE_TENANT_ID=seu_tenant_id_aqui
AZURE_SUBSCRIPTION_ID=sua_subscription_id_aqui

# ==========================================
# TERRAFORM — variáveis sensíveis
# (alternativa ao terraform.tfvars)
# ==========================================
TF_VAR_synapse_sql_admin_password=defina_uma_senha_forte_aqui

# ==========================================
# STORAGE ACCOUNT E CONEXÃO
# ==========================================
STORAGE_ACCOUNT_NAME=stalfalfabetizacao
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net"

# ==========================================
# EVENT HUBS — SIMULAÇÃO DE STREAMING
# (arquitetura pretendida; execução simulada no desafio)
# ==========================================
EH_CONNECTION_STRING="Endpoint=sb://...;SharedAccessKeyName=...;SharedAccessKey=...;EntityPath=..."

# ==========================================
# PIPELINE BATCH / SIMULAÇÃO LOCAL
# ==========================================
TABLE_NAME=alfabetizacao
AMBIENTE=desenvolvimento

# ==========================================
# NOTEBOOKS / AZURE KEY VAULT
# ==========================================
KEY_VAULT_URL=https://kv-alfabetizacao.vault.azure.net/
KEY_VAULT_SECRET_NAME=storage-account-key